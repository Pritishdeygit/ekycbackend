NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://localhost:27017/ekyc_db
CLIENT_URL=http://localhost:3000

# eKYC Provider
EKYC_API_BASE_URL=https://api.your-ekyc-provider.com
EKYC_API_KEY=your_api_key_here

# Storage (S3 or local in dev)
STORAGE_TYPE=local          # 'local' | 's3'


# Security
ENCRYPTION_KEY=32-char-secret-key-here